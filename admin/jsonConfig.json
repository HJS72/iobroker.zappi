{
  "i18n": true,
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": "Main settings",
      "items": {
        "username": {
          "type": "text",
          "label": "Hub Serialnumber",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "password": {
          "type": "password",
          "label": "API Key",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "apiBaseUrl": {
          "type": "text",
          "label": "API Base URL",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Default: https://s18.myenergi.net. ASN redirects are handled automatically."
        },
        "pollInterval": {
          "type": "number",
          "label": "Polling interval (seconds)",
          "newLine": false,
          "min": 10,
          "max": 300,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "phases": {
          "type": "number",
          "label": "Charging phases (1 or 3)",
          "newLine": true,
          "min": 1,
          "max": 3,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Used for converting target power to current"
        },
        "defaultZappiSerial": {
          "type": "text",
          "label": "Default Zappi Serial (optional)",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "currentLimitPathTemplate": {
          "type": "text",
          "label": "Current-limit API path template",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "help": "Optional. Example: /cgi-set-device-limit-Z{serial}-{amps}. Variables: {serial}, {amps}, {powerW}."
        }
      }
    }
  }
}
