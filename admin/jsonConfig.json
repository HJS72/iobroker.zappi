{
  "i18n": true,
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": "Main settings",
      "items": {
        "connectionMode": {
          "type": "select",
          "label": "Connection mode",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "options": [
            {
              "label": "Integrated OCPP server (direct)",
              "value": "server"
            },
            {
              "label": "Bridge to existing OCPP adapter states",
              "value": "bridge"
            }
          ]
        },
        "connectorStatusStateId": {
          "type": "text",
          "label": "OCPP connector status state ID",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "help": "Required. Example: ocpp.0.chargePoint01.connectorStatus"
        },
        "currentStateId": {
          "type": "text",
          "label": "OCPP measured current state ID",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "help": "Optional. Example: ocpp.0.chargePoint01.currentA"
        },
        "powerStateId": {
          "type": "text",
          "label": "OCPP measured power state ID",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "help": "Optional. Example: ocpp.0.chargePoint01.powerW"
        },
        "phaseReadStateId": {
          "type": "text",
          "label": "OCPP phase status state ID",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "help": "Optional. Value should represent 1/3 phases (single/three/1/3)."
        },
        "phaseSetStateId": {
          "type": "text",
          "label": "OCPP phase command state ID",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "help": "Required for phase switching control."
        },
        "currentSetStateId": {
          "type": "text",
          "label": "OCPP current command state ID",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "help": "Required for maxCurrentA and targetPowerW control."
        },
        "pollInterval": {
          "type": "number",
          "label": "Polling interval (seconds)",
          "newLine": true,
          "min": 5,
          "max": 300,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "connectedStatusValues": {
          "type": "text",
          "label": "Connector states considered as vehicle connected",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Comma separated list. Default: Preparing,Charging,SuspendedEV,SuspendedEVSE,Finishing"
        },
        "phaseSingleValue": {
          "type": "text",
          "label": "Value to write for single phase",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Default: 1"
        },
        "phaseThreeValue": {
          "type": "text",
          "label": "Value to write for three phase",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Default: 3"
        },
        "requireWriteAuthorization": {
          "type": "checkbox",
          "label": "Require authorization for write controls",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "If enabled, phase and power/current controls require authorization code first."
        },
        "authorizationCode": {
          "type": "password",
          "label": "Authorization code",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Write this code to control.authorizeCode to unlock controls temporarily."
        },
        "authorizationTimeoutSec": {
          "type": "number",
          "label": "Authorization timeout (seconds)",
          "newLine": true,
          "min": 30,
          "max": 3600,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "How long controls stay unlocked after successful authorization."
        },
        "automationEnabled": {
          "type": "checkbox",
          "label": "Enable built-in automation",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Adapter directly controls target power/current in a loop."
        },
        "automationIntervalSec": {
          "type": "number",
          "label": "Automation interval (seconds)",
          "newLine": false,
          "min": 10,
          "max": 300,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Control loop interval when automation is enabled."
        },
        "autoPowerInputStateId": {
          "type": "text",
          "label": "Automation input power state ID",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "help": "Required for automation. Example: javascript.0.pv.surplusW"
        },
        "automationOnlyWhenConnected": {
          "type": "checkbox",
          "label": "Automation only when vehicle connected",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "autoMinPowerW": {
          "type": "number",
          "label": "Automation min power (W)",
          "newLine": false,
          "min": 1400,
          "max": 22000,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "autoMaxPowerW": {
          "type": "number",
          "label": "Automation max power (W)",
          "newLine": true,
          "min": 1400,
          "max": 22000,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "autoPhaseSwitchEnabled": {
          "type": "checkbox",
          "label": "Automation phase switching enabled",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "autoSinglePhaseBelowW": {
          "type": "number",
          "label": "Single phase below power (W)",
          "newLine": true,
          "min": 1400,
          "max": 22000,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Used when automation phase switching is enabled."
        },
        "autoAuthorizeEnabled": {
          "type": "checkbox",
          "label": "Auto-authorization enabled",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Automatically refreshes authorization while adapter is running."
        },
        "autoAuthorizeIntervalSec": {
          "type": "number",
          "label": "Auto-authorization interval (seconds)",
          "newLine": true,
          "min": 30,
          "max": 3600,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "ocppServerHost": {
          "type": "text",
          "label": "OCPP server host",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Used in server mode. Default: 0.0.0.0"
        },
        "ocppServerPort": {
          "type": "number",
          "label": "OCPP server port",
          "newLine": false,
          "min": 1,
          "max": 65535,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Used in server mode. Default: 9220"
        },
        "ocppTlsEnabled": {
          "type": "checkbox",
          "label": "Enable TLS (WSS)",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "ocppTlsKeyPath": {
          "type": "text",
          "label": "TLS key path",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "ocppTlsCertPath": {
          "type": "text",
          "label": "TLS cert path",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "serverAuthToken": {
          "type": "password",
          "label": "Server auth token (query ?token=...)",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "allowedChargePointIds": {
          "type": "text",
          "label": "Allowed charge point IDs",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Comma separated allowlist. Empty allows all IDs."
        },
        "ocppHeartbeatIntervalSec": {
          "type": "number",
          "label": "OCPP heartbeat interval response (seconds)",
          "newLine": true,
          "min": 10,
          "max": 600,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "ocppRequestTimeoutSec": {
          "type": "number",
          "label": "OCPP outgoing request timeout (seconds)",
          "newLine": false,
          "min": 5,
          "max": 300,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "ocppPhaseConfigKey": {
          "type": "text",
          "label": "OCPP phase config key",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "help": "Used for ChangeConfiguration in server mode. Default: NumberOfPhases"
        },
        "defaultIdTag": {
          "type": "text",
          "label": "Default idTag",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 4
        },
        "defaultConnectorId": {
          "type": "number",
          "label": "Default connectorId",
          "newLine": true,
          "min": 1,
          "max": 8,
          "sm": 12,
          "md": 6,
          "lg": 4
        }
      }
    }
  }
}
